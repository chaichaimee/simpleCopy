#: __init__.py:221
msgid "Append"
msgstr "சேர்"

#: clipboard_utils.py:126
msgid "Appended"
msgstr "சேர்க்கப்பட்டது"

#: clipboard_utils.py:102
msgid "Cannot append to non-text clipboard content"
msgstr "உரை அல்லாத கிளிப்போர்டு உள்ளடக்கத்தைச் சேர்க்க முடியாது"

#: __init__.py:169
msgid "Clean"
msgstr "சுத்தம் செய்"

#: clipboard_utils.py:126
msgid "Copied"
msgstr "நகலெடுக்கப்பட்டது"

#: __init__.py:111
#: __init__.py:123
msgid "Copy"
msgstr "நகலெடு"

#: __init__.py:230
msgid "Copy Until Last"
msgstr "கடைசி வரை நகலெடு"

#: __init__.py:75
msgid "Error during append operation"
msgstr "சேர்க்கும் செயல்பாட்டின் போது பிழை"

#: clipboard_utils.py:133
msgid "Error writing to clipboard"
msgstr "கிளிப்போர்டில் எழுதும்போது பிழை"

#: __init__.py:113
msgid "No URL"
msgstr "URL இல்லை"

#: __init__.py:125
msgid "No link found"
msgstr "இணைப்பு எதுவும் காணப்படவில்லை"

#: __init__.py:64
msgid "No text selected to append"
msgstr "சேர்ப்பதற்கு உரை எதுவும் தேர்ந்தெடுக்கப்படவில்லை"

#: __init__.py:29
msgid "Simple Copy"
msgstr "Simple Copy"

#: __init__.py:78
msgid "copy URL (single) copy hyper link (double)"
msgstr "URL நகலெடு (ஒற்றை) ஹைப்பர் லிங்க் நகலெடு (இரட்டை)"

#: __init__.py:132
msgid "copy and append (single) clear (double)"
msgstr "நகலெடுத்து சேர் (ஒற்றை) சுத்தம் செய் (இரட்டை)"

#: __init__.py:177
msgid "copy last speech (single) append last speech (double) copy until last speech (triple) open record speech (quadruple)"
msgstr "கடைசி உரையை நகலெடு (ஒற்றை) கடைசி உரையைச் சேர் (இரட்டை) கடைசி உரை வரை நகலெடு (மூன்று முறை) பேச்சுப் பதிவைத் திற (நான்கு முறை)"